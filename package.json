{
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "@tootallnate/once": "^3.0.1",
    "picomatch": "2.3.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "rootDir": "..",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/frontend/setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/frontend/**/test-*.js"
    ],
    "collectCoverageFrom": [
      "<rootDir>/custom_components/**/*.js",
      "!<rootDir>/custom_components/**/test-*.js",
      "!<rootDir>/custom_components/**/*..test.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!jsdom)/"
    ]
  },
  "dependencies": {
    "minimatch": "^3.1.5"
  }
}
